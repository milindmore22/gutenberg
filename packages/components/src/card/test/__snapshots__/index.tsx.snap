exports[`Card Card component should render correctly 1`] = `
.emotion-0 {
  box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.1);
  outline: none;
  border-radius: calc(8px - 1px);
}

.emotion-1 {
  height: 100%;
}

.emotion-2 {
  border-bottom: 1px solid;
  box-sizing: border-box;
  border-color: rgba(0, 0, 0, 0.1);
  padding: calc(4px * 4) calc(4px * 6);
}

.emotion-2:last-child {
  border-bottom: none;
}

.emotion-2:first-of-type {
  border-top-left-radius: calc(8px - 1px);
  border-top-right-radius: calc(8px - 1px);
}

.emotion-2:last-of-type {
  border-bottom-left-radius: calc(8px - 1px);
  border-bottom-right-radius: calc(8px - 1px);
}

.emotion-3 {
  box-sizing: border-box;
  height: auto;
  max-height: 100%;
}

.emotion-4:first-of-type {
  border-top-left-radius: calc(8px - 1px);
  border-top-right-radius: calc(8px - 1px);
}

.emotion-4:last-of-type {
  border-bottom-left-radius: calc(8px - 1px);
  border-bottom-right-radius: calc(8px - 1px);
}

.emotion-5 {
  padding: calc(4px * 4) calc(4px * 6);
}

.emotion-9 {
  box-sizing: border-box;
  display: block;
  width: 100%;
}

.emotion-10 {
  border-color: rgba(0, 0, 0, 0.1);
}

.emotion-14 {
  box-sizing: border-box;
  overflow: hidden;
}

.emotion-14>img,
.emotion-14>iframe {
  display: block;
  height: auto;
  max-width: 100%;
  width: 100%;
}

.emotion-16 {
  border-top: 1px solid;
  box-sizing: border-box;
  border-color: rgba(0, 0, 0, 0.1);
  padding: calc(4px * 4) calc(4px * 6);
}

.emotion-16:first-of-type {
  border-top: none;
}

.emotion-16:first-of-type {
  border-top-left-radius: calc(8px - 1px);
  border-top-right-radius: calc(8px - 1px);
}

.emotion-16:last-of-type {
  border-bottom-left-radius: calc(8px - 1px);
  border-bottom-right-radius: calc(8px - 1px);
}

.emotion-17 {
  background: transparent;
  display: block;
  margin: 0!important;
  pointer-events: none;
  position: absolute;
  will-change: box-shadow;
  border-radius: inherit;
  bottom: 0;
  box-shadow: 0 0px 0px 0 rgba(0, 0, 0, 0);
  opacity: 1;
  left: 0;
  right: 0;
  top: 0;
}

@media not ( prefers-reduced-motion ) {
  .emotion-17 {
    -webkit-transition: box-shadow 200ms cubic-bezier(0.08, 0.52, 0.52, 1);
    transition: box-shadow 200ms cubic-bezier(0.08, 0.52, 0.52, 1);
  }
}

.emotion-18 {
  border-radius: 8px;
}

<div>
  <div
    class="style-surface components-surface emotion-0 components-card"
    data-wp-c16t="true"
    data-wp-component="Card"
  >
    <div
      class="emotion-1"
    >
      <div
        class="style-flex style-items-row style-expanded-row components-flex emotion-2 components-card__header components-card-header"
        data-wp-c16t="true"
        data-wp-component="CardHeader"
        style="--wp-components-flex-align: center; --wp-components-flex-direction: row; --wp-components-flex-wrap: nowrap; --wp-components-flex-gap: calc(4px * 2); --wp-components-flex-justify: space-between;"
      >
        Card Header
      </div>
      <div
        class="emotion-3 emotion-4 emotion-5 components-card__body components-card-body"
        data-wp-c16t="true"
        data-wp-component="CardBody"
      >
        Card Body 1
      </div>
      <div
        class="emotion-3 emotion-4 emotion-5 components-card__body components-card-body"
        data-wp-c16t="true"
        data-wp-component="CardBody"
      >
        Card Body 2
      </div>
      <hr
        aria-orientation="horizontal"
        class="style-divider components-divider emotion-9 emotion-10 components-card__divider components-card-divider"
        data-wp-c16t="true"
        data-wp-component="CardDivider"
        role="separator"
      />
      <div
        class="emotion-3 emotion-4 emotion-5 components-card__body components-card-body"
        data-wp-c16t="true"
        data-wp-component="CardBody"
      >
        Card Body 3
